@model IReadOnlyList<TaskFlow.Web.Domain.Ticket>

@{
    ViewData["Title"] = "Tickets";
}

<h1>Tickets</h1>

<table class="table table-striped">
    <thead>
        <tr>
            <th>#</th>
            <th>Titre</th>
            <th>Statut</th>
            <th>Créé le (UTC)</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var ticket in Model)
        {
            <tr>
                <td>@ticket.Id</td>
                <td>@ticket.Title</td>
                <td>@ticket.Status</td>
                <td>@ticket.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
            </tr>
        }
    </tbody>
</table>
